<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
     <key>Label</key>
     <string>com.quant-system.console</string>

     <key>ProgramArguments</key>
     <array>
          <string>/bin/bash</string>
          <string>/absolute/path/to/quant-system/scripts/run_web_console.sh</string>
     </array>

      <key>WorkingDirectory</key>
     <string>/absolute/path/to/quant-system</string>

      <key>StandardOutPath</key>
     <string>/absolute/path/to/quant-system/logs/console.log</string>

      <key>StandardErrorPath</key>
     <string>/absolute/path/to/quant-system/logs/console-error.log</string>

      <key>KeepAlive</key>
     <true/>

      <key>RunAtLoad</key>
     <true/>

      <key>Disabled</key>
     <true/>
</dict>
</plist>
