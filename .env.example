# Copy to .env for local/server runs. Do not commit real secrets.

QUANT_ENV=dev
QUANT_TRADING_MODE=paper
QUANT_LIVE_TRADING_ENABLED=false
QUANT_LIVE_TRADING_CONFIRMATION=
QUANT_MAX_ORDER_NOTIONAL=
QUANT_BROKER=
# Short selling remains disabled unless every bounded-risk limit is explicit.
QUANT_SHORT_SELLING_ENABLED=false
QUANT_MAX_SHORT_POSITION_NOTIONAL=
QUANT_MAX_TOTAL_SHORT_EXPOSURE_PCT_EQUITY=
QUANT_MAX_GROSS_EXPOSURE_PCT_EQUITY=
QUANT_MIN_BUYING_POWER_BUFFER_PCT=

QUANT_CMD=.venv/bin/quant
QUANT_STRATEGY=momentum
QUANT_SYMBOL=AAPL
QUANT_PROVIDER=yfinance
QUANT_START=2024-01-01
QUANT_END=
QUANT_DATA=data/sample_prices.csv
QUANT_QUANTITY=1
QUANT_INITIAL_CASH=100000
QUANT_ITERATIONS=1
QUANT_INTERVAL_SECONDS=0
QUANT_MIN_ROWS=1
QUANT_SKIP_VALIDATION=false

QUANT_STATE_PATH=data/paper/state/default.json
QUANT_SIGNAL_OUTPUT_DIR=data/paper/signals
QUANT_RUN_OUTPUT_DIR=data/scheduler/latest
QUANT_RAW_DIR=data/raw
QUANT_NORMALIZED_DIR=data/normalized
QUANT_VALIDATION_DIR=data/validation
QUANT_METADATA_DIR=data/metadata
QUANT_WORKFLOW_OUTPUT_DIR=data/workflows/paper-signal-refresh
QUANT_LOCK_PATH=data/locks/paper-signal-refresh.lock
QUANT_LOCK_STALE_AFTER_SECONDS=7200
QUANT_LOG_DIR=logs

# Dry-run refresh wrapper defaults. These keep the live-shaped dry-run path
# separate from paper account state while still using the same provider input.
QUANT_DRY_RUN_OUTPUT_DIR=data/dry_run/orders
QUANT_DRY_RUN_RUN_OUTPUT_DIR=data/scheduler/dry-run
QUANT_DRY_RUN_WORKFLOW_OUTPUT_DIR=data/workflows/dry-run-refresh
QUANT_DRY_RUN_LOCK_PATH=data/locks/dry-run-refresh.lock
QUANT_DRY_RUN_COMPARISON_OUTPUT_PATH=data/dry_run/comparison/latest.json
QUANT_DRY_RUN_BROKER_NAME=dry-run
QUANT_DRY_RUN_PUBLISH_STATUS_PATH=
QUANT_DRY_RUN_HEALTH_RUN_RECORDS_DIR=

# Alpaca paper refresh wrapper defaults. These are paper-broker paths only; do
# not point them at a real-money account.
QUANT_ALPACA_PAPER_API_KEY=
QUANT_ALPACA_PAPER_SECRET_KEY=
QUANT_ALPACA_PAPER_ACCOUNT_ID=
QUANT_ALPACA_PAPER_URL_OVERRIDE=
QUANT_ALPACA_PAPER_WORKFLOW_OUTPUT_DIR=data/workflows/alpaca-paper-refresh
QUANT_ALPACA_PAPER_LOCK_PATH=data/locks/alpaca-paper-refresh.lock
QUANT_ALPACA_PAPER_ORDER_OUTPUT_DIR=data/live/orders
QUANT_ALPACA_PAPER_FILL_OUTPUT_DIR=data/live/fills
QUANT_ALPACA_PAPER_SNAPSHOT_OUTPUT_DIR=data/live/account_snapshots
QUANT_ALPACA_PAPER_RECONCILIATION_OUTPUT_PATH=data/live/reconciliation/latest.json
QUANT_ALPACA_PAPER_CASH_TOLERANCE=0.01
QUANT_ALPACA_PAPER_PUBLISH_STATUS_AFTER_RUN=false
QUANT_ALPACA_PAPER_PUBLISH_STATUS_PATH=site/status.json
QUANT_ALPACA_PAPER_PUBLISH_STATUS_FAIL_ON_FAILED=false

# Web console API key. Set to a random value to enable authentication.
# Generate with: openssl rand -hex 32
QUANT_CONSOLE_API_KEY=
