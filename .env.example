# Copy to .env for local/server runs. Do not commit real secrets.

QUANT_ENV=dev
LIVE_TRADING_ENABLED=false

QUANT_CMD=.venv/bin/quant
QUANT_STRATEGY=momentum
QUANT_SYMBOL=AAPL
QUANT_DATA=data/sample_prices.csv
QUANT_QUANTITY=1
QUANT_INITIAL_CASH=100000
QUANT_ITERATIONS=1
QUANT_INTERVAL_SECONDS=0
QUANT_MIN_ROWS=1
QUANT_SKIP_VALIDATION=false

QUANT_STATE_PATH=data/paper/state/default.json
QUANT_SIGNAL_OUTPUT_DIR=data/paper/signals
QUANT_RUN_OUTPUT_DIR=data/scheduler/latest
QUANT_LOG_DIR=logs
